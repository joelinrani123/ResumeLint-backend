# Copy this file to .env and fill in real values before running
# docker-compose, or export these as real environment variables before
# running the jar directly.

# --- Server ---
PORT=8080

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=resumelint
DB_USER=root
DB_PASSWORD=change-me

# --- Auth ---
# REQUIRED. Generate with: openssl rand -base64 48
SESSION_SECRET=replace-this-with-a-long-random-secret-at-least-32-characters

# --- CORS ---
# Comma-separated list of allowed origins, or * for any origin.
CORS_ALLOWED_ORIGINS=*
